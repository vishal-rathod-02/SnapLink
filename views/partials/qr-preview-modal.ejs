<div
  id="qrPreviewModal"
  class="qr-share-modal"
  aria-hidden="true"
  role="dialog"
  aria-modal="true"
  aria-labelledby="qrPreviewTitle"
>
  <div class="qr-share-backdrop" data-qr-modal-close></div>
  <div class="qr-share-shell" role="document">
    <button
      type="button"
      class="qr-share-close"
      aria-label="Close QR share card"
      data-qr-modal-close
    >
      <i class="bi bi-x-lg"></i>
    </button>

    <div class="qr-share-panel">
      <section class="qr-share-copy">
        <span class="qr-share-kicker">Share Ready</span>
        <h3 class="h4 mb-2" id="qrPreviewTitle">Scan To Open</h3>
        <p class="text-secondary mb-3">
          A clean share card for quick scans, stories, posters, and lightweight handoffs.
        </p>

        <div class="qr-share-url-card mb-3">
          <div class="qr-share-label">Short URL</div>
          <div id="qrPreviewShortUrl" class="qr-share-url text-break"></div>
          <p class="qr-share-subtle mb-0 mt-2">
            Share the QR visually or copy the link directly.
          </p>
        </div>

        <div class="d-flex flex-wrap gap-2">
          <button type="button" class="btn btn-outline-primary" id="qrPreviewCopyButton">
            <i class="bi bi-clipboard me-1"></i>Copy Link
          </button>
          <a id="qrPreviewOpenLink" class="btn btn-primary" href="#" target="_blank" rel="noopener noreferrer">
            Open Link
          </a>
        </div>
      </section>

      <section class="qr-share-visual">
        <div class="qr-share-artboard">
          <div class="qr-share-pattern-shell">
            <img id="qrPreviewImage" src="" alt="QR code preview" />
          </div>
        </div>
        <p class="qr-share-subtle text-center mt-3 mb-0">
          Use `PNG` for quick sharing and `SVG` for crisp print quality.
        </p>
        <div class="qr-share-downloads">
          <a id="qrPreviewPngLink" class="btn btn-outline-dark" href="#">
            PNG Download
          </a>
          <a id="qrPreviewSvgLink" class="btn btn-outline-dark" href="#">
            SVG Download
          </a>
        </div>
      </section>
    </div>
  </div>
</div>
