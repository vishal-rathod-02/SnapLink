<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include('partials/head') %>
  </head>
  <body>
    <%- include('partials/navbar', { activePage }) %>

    <main class="container py-5">
      <%- include('partials/flash-messages') %>

      <section class="hero-panel panel-card p-4 p-lg-5 mb-4 reveal">
        <div class="row align-items-center g-4">
          <div class="col-lg-7">
            <div class="hero-brand-lockup">
              <span class="hero-brand-orb"></span>
              <div class="hero-brand-copy">
                <span class="hero-brand-name">SnapLink</span>
                <span class="hero-slogan">Snap it. Share it.</span>
              </div>
            </div>
            <h1 class="hero-title display-5 mb-3">
              Transform long links into shareable smart URLs
            </h1>
            <p class="lead text-secondary mb-0">
              Shorten links instantly, track click behavior, and monitor activity with a
              premium dashboard experience.
            </p>
          </div>
          <div class="col-lg-5">
            <div class="row g-3">
              <div class="col-6">
                <article class="metric-card h-100">
                  <div class="metric-label"><%= currentUser ? 'Your Links' : 'Platform Links' %></div>
                  <div class="metric-value"><%= formatNumber(stats.totalUrls) %></div>
                </article>
              </div>
              <div class="col-6">
                <article class="metric-card h-100">
                  <div class="metric-label"><%= currentUser ? 'Your Clicks' : 'Platform Clicks' %></div>
                  <div class="metric-value"><%= formatNumber(stats.totalClicks) %></div>
                </article>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="panel-card create-url-panel p-4 p-lg-5 mb-4 reveal">
        <% if (currentUser) { %>
        <h2 class="h4 mb-3">Create your short URL</h2>
        <form method="POST" action="/shorten" id="shortenForm" class="d-flex flex-column gap-3" novalidate>
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />

          <div>
            <label class="form-label create-form-label" for="originalUrl">Destination URL</label>
            <div class="input-group input-group-lg modern-input-group">
              <span class="input-group-text"><i class="bi bi-globe-americas"></i></span>
              <input
                type="text"
                class="form-control"
                id="originalUrl"
                name="originalUrl"
                placeholder="https://example.com/your-very-long-url"
                required
                value="<%= previousInput %>"
              />
              <button class="btn btn-gradient px-4 btn-generate" type="submit">
                <span class="btn-label">Generate</span>
                <span class="btn-loader" aria-hidden="true">
                  <span></span>
                  <span></span>
                  <span></span>
                </span>
              </button>
            </div>
          </div>

          <div class="alias-field-shell">
            <div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-2">
              <label class="form-label create-form-label mb-0" for="customAlias">Custom alias</label>
              <span class="alias-optional-chip">Optional</span>
            </div>
            <div class="input-group alias-input-group">
              <span class="input-group-text">/</span>
              <input
                type="text"
                class="form-control"
                id="customAlias"
                name="customAlias"
                placeholder="summer-sale"
                maxlength="32"
                value="<%= previousAlias %>"
              />
            </div>
            <div class="form-text alias-help-text">
              Use 3 to 32 letters, numbers, hyphens, or underscores. We automatically reserve app route names.
            </div>
          </div>
        </form>

        <% if (errorMessage) { %>
        <div class="alert alert-danger mt-3 mb-0 d-flex align-items-center gap-2" role="alert">
          <i class="bi bi-exclamation-triangle-fill"></i>
          <span><%= errorMessage %></span>
        </div>
        <% } %>
        <% } else { %>
        <div class="guest-create-shell">
          <div class="guest-create-copy">
            <span class="guest-create-kicker">Account Required</span>
            <h2 class="h3 mb-3">Create short links inside your own private workspace</h2>
            <p class="lead text-secondary mb-0">
              Sign in before generating links so every URL stays owned by you, analytics stay
              private, and management actions remain secure.
            </p>
          </div>
          <div class="guest-cta-actions">
            <a href="/signup" class="btn btn-gradient btn-lg">Create Account</a>
            <a href="/login" class="btn btn-outline-dark btn-lg">Sign In</a>
          </div>
        </div>

        <div class="row g-3 mt-2">
          <div class="col-md-4">
            <article class="guest-feature-card h-100">
              <i class="bi bi-folder2-open"></i>
              <h3 class="h6 mb-2">Owned link library</h3>
              <p class="mb-0 text-secondary small">
                Save every generated URL to your own account instead of a shared public pool.
              </p>
            </article>
          </div>
          <div class="col-md-4">
            <article class="guest-feature-card h-100">
              <i class="bi bi-graph-up-arrow"></i>
              <h3 class="h6 mb-2">Private analytics</h3>
              <p class="mb-0 text-secondary small">
                Track clicks, activity, and top performers without exposing your data to everyone.
              </p>
            </article>
          </div>
          <div class="col-md-4">
            <article class="guest-feature-card h-100">
              <i class="bi bi-shield-lock"></i>
              <h3 class="h6 mb-2">Secure management</h3>
              <p class="mb-0 text-secondary small">
                Delete, revisit, and manage your links only after authentication.
              </p>
            </article>
          </div>
        </div>
        <% } %>
      </section>

      <% if (shortResult) { %>
      <section class="panel-card p-4 mb-4 reveal success-panel">
        <div class="success-panel-layout">
          <div class="success-panel-copy">
            <div class="d-flex align-items-center gap-2 mb-2">
              <span class="success-dot"></span>
              <h3 class="h5 mb-0">Short URL ready</h3>
              <% if (shortResult.isReused) { %>
              <span class="badge text-bg-warning">Existing link reused</span>
              <% } else { %>
              <span class="badge text-bg-success">New link created</span>
              <% } %>
              <% if (shortResult.isCustomAlias) { %>
              <span class="badge text-bg-primary">Custom alias</span>
              <% } %>
            </div>
            <a class="short-link fw-semibold fs-5" href="<%= shortResult.shortUrl %>" target="_blank">
              <%= shortResult.shortUrl %>
            </a>
            <p class="mb-0 mt-2 text-secondary text-break">
              Original: <%= shortResult.originalUrl %>
            </p>
            <div class="success-panel-actions">
              <button
                class="btn btn-outline-primary"
                data-copy="<%= shortResult.shortUrl %>"
                type="button"
                data-bs-toggle="tooltip"
                data-bs-title="Copy short URL"
              >
                <i class="bi bi-clipboard me-1"></i>Copy
              </button>
              <a class="btn btn-primary" href="<%= shortResult.shortUrl %>" target="_blank">
                Open
              </a>
            </div>
          </div>

          <article class="qr-preview-card">
            <div class="d-flex align-items-center justify-content-between gap-3 mb-3">
              <div>
                <span class="qr-preview-kicker">Quick Share</span>
                <h4 class="h6 mb-0 mt-2">QR code for this link</h4>
              </div>
              <i class="bi bi-qr-code qr-preview-icon" aria-hidden="true"></i>
            </div>
            <div class="qr-preview-frame">
              <img
                src="<%= shortResult.qrPreviewUrl %>"
                alt="QR code preview for <%= shortResult.shortUrl %>"
                loading="lazy"
              />
            </div>
            <div class="qr-preview-actions">
              <button
                type="button"
                class="btn btn-outline-primary"
                data-qr-preview-trigger
                data-qr-image-url="<%= shortResult.qrPreviewUrl %>"
                data-qr-short-url="<%= shortResult.shortUrl %>"
                data-qr-original-url="<%= shortResult.originalUrl %>"
                data-qr-type="<%= shortResult.isCustomAlias ? 'Custom alias' : 'Default code' %>"
                data-qr-clicks="<%= formatNumber(shortResult.clicks || 0) %>"
                data-qr-created="<%= formatDate(shortResult.createdAt) %>"
                data-qr-last-visit="<%= shortResult.lastVisitedAt ? formatRelativeTime(shortResult.lastVisitedAt) : 'Not visited yet' %>"
                data-qr-download-png="<%= shortResult.qrPngDownloadUrl %>"
                data-qr-download-svg="<%= shortResult.qrSvgDownloadUrl %>"
                data-qr-open-url="<%= shortResult.shortUrl %>"
              >
                Preview QR
              </button>
              <a class="btn btn-outline-dark" href="<%= shortResult.qrPngDownloadUrl %>">
                PNG
              </a>
              <a class="btn btn-outline-dark" href="<%= shortResult.qrSvgDownloadUrl %>">
                SVG
              </a>
            </div>
          </article>
        </div>
      </section>
      <% } %>

      <% if (currentUser) { %>
      <section class="panel-card p-4 p-lg-5 reveal recent-links-card">
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-2 mb-3">
          <h2 class="h4 mb-0">Recently generated links</h2>
          <a href="/dashboard" class="btn btn-sm btn-outline-dark">
            Open Dashboard <i class="bi bi-arrow-right ms-1"></i>
          </a>
        </div>

        <% if (!recentUrls.length) { %>
        <div class="empty-state">
          <i class="bi bi-link-45deg"></i>
          <p class="mb-0">No links yet. Create your first short URL above.</p>
        </div>
        <% } else { %>
        <div class="table-responsive recent-table-shell">
          <table class="table table-modern align-middle">
            <thead>
              <tr>
                <th>Short URL</th>
                <th>Original URL</th>
                <th>Clicks</th>
                <th>Created</th>
                <th class="text-end">Actions</th>
              </tr>
            </thead>
            <tbody>
              <% recentUrls.forEach((url) => { %>
              <tr>
                <td>
                  <a href="<%= baseUrl %>/<%= url.shortCode %>" target="_blank">
                    <%= baseUrl %>/<%= url.shortCode %>
                  </a>
                  <% if (url.isCustomAlias) { %>
                  <span class="badge text-bg-primary badge-inline-link">Custom</span>
                  <% } %>
                </td>
                <td class="text-break"><%= url.originalUrl %></td>
                <td>
                  <span class="data-pill"><%= formatNumber(url.clicks) %></span>
                </td>
                <td><%= formatDate(url.createdAt) %></td>
                <td class="text-end">
                  <div class="d-inline-flex flex-wrap justify-content-end gap-2">
                    <a
                      class="btn btn-sm btn-outline-primary qr-inline-action"
                      href="#"
                      role="button"
                      data-qr-preview-trigger
                      data-qr-image-url="/urls/<%= url._id %>/qr?format=svg&size=220"
                      data-qr-short-url="<%= baseUrl %>/<%= url.shortCode %>"
                      data-qr-original-url="<%= url.originalUrl %>"
                      data-qr-type="<%= url.isCustomAlias ? 'Custom alias' : 'Default code' %>"
                      data-qr-clicks="<%= formatNumber(url.clicks) %>"
                      data-qr-created="<%= formatDate(url.createdAt) %>"
                      data-qr-last-visit="<%= url.lastVisitedAt ? formatRelativeTime(url.lastVisitedAt) : 'Not visited yet' %>"
                      data-qr-download-png="/urls/<%= url._id %>/qr?format=png&size=320&download=1"
                      data-qr-download-svg="/urls/<%= url._id %>/qr?format=svg&size=320&download=1"
                      data-qr-open-url="<%= baseUrl %>/<%= url.shortCode %>"
                      data-bs-toggle="tooltip"
                      data-bs-title="Preview QR"
                    >
                      <i class="bi bi-qr-code"></i>
                    </a>
                  </div>
                </td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
        <% } %>
      </section>
      <% } else { %>
      <section class="panel-card p-4 p-lg-5 reveal recent-links-card">
        <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3 mb-4">
          <div>
            <h2 class="h4 mb-1">Why the app asks you to sign in first</h2>
            <p class="text-secondary mb-0">
              Authentication keeps link ownership clear, protects analytics, and prevents the
              shortener from becoming an open spam endpoint.
            </p>
          </div>
          <a href="/signup" class="btn btn-gradient">
            Start Your Workspace <i class="bi bi-arrow-right ms-1"></i>
          </a>
        </div>

        <div class="row g-3">
          <div class="col-md-4">
            <article class="metric-card h-100">
              <div class="metric-label">Owned by You</div>
              <div class="h5 mb-2">Personal dashboard</div>
              <p class="mb-0 text-secondary small">
                Your links, clicks, and activity history stay scoped to your account.
              </p>
            </article>
          </div>
          <div class="col-md-4">
            <article class="metric-card h-100">
              <div class="metric-label">Protected Flow</div>
              <div class="h5 mb-2">Safer creation</div>
              <p class="mb-0 text-secondary small">
                Requiring login reduces abuse and keeps production usage easier to moderate.
              </p>
            </article>
          </div>
          <div class="col-md-4">
            <article class="metric-card h-100">
              <div class="metric-label">Ready for Growth</div>
              <div class="h5 mb-2">Premium features</div>
              <p class="mb-0 text-secondary small">
                Account-based links unlock custom aliases, exports, QR codes, and richer analytics.
              </p>
            </article>
          </div>
        </div>
      </section>
      <% } %>
    </main>

    <%- include('partials/delete-confirm-modal') %>
    <%- include('partials/qr-preview-modal') %>
    <%- include('partials/copy-feedback') %>

    <%- include('partials/scripts') %>
  </body>
</html>
